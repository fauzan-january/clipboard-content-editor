msgid "Clipboard Content Editor - What's New"
msgstr "Clipboard Content Editor - Apa yang Baru"

msgid "Clipboard Content Editor - Installation"
msgstr "Clipboard Content Editor - Instalasi"

msgid "Do you want to continue installation or see what's new first?"
msgstr "Apakah Anda ingin melanjutkan instalasi atau melihat apa yang baru terlebih dahulu?"

msgid "&See what's new"
msgstr "Lihat Apa yang Baru"

msgid "&Continue Installation"
msgstr "Lanjutkan Instalasi"

msgid "What's new information is unavailable."
msgstr "Informasi Apa yang Baru tidak tersedia."

msgid "&OK"
msgstr "OK"

msgid "Clipboard information: {chars} characters, {words} words, {lines} lines"
msgstr "Informasi clipboard: {chars} karakter, {words} kata, {lines} baris"

msgid "Clipboard is empty"
msgstr "Clipboard kosong"

msgid "Clipboard Content Editor"
msgstr "Clipboard Content Editor"

msgid "Clipboard content:"
msgstr "Isi clipboard:"

msgid "&Information"
msgstr "Informasi"

msgid "&Find"
msgstr "Cari"

msgid "&Replace"
msgstr "Ganti"

msgid "Save (Ctrl+S)"
msgstr "Simpan (Ctrl+S)"

msgid "Cancel (Esc)"
msgstr "Batal (Esc)"

msgid "Clipboard updated"
msgstr "Clipboard diperbarui"

msgid "Failed to update clipboard"
msgstr "Gagal memperbarui clipboard"

msgid "Changes canceled"
msgstr "Perubahan dibatalkan"

msgid "You have unsaved changes. Discard them?"
msgstr "Anda memiliki perubahan yang belum disimpan. Buang perubahan ini?"

msgid "Opens a clipboard editor to modify the current clipboard text."
msgstr "Membuka editor clipboard untuk mengubah teks clipboard saat ini."

msgid "Shows information about the current clipboard text."
msgstr "Menampilkan informasi tentang teks clipboard saat ini."

msgid "Restores the previous clipboard content from backup."
msgstr "Memulihkan isi clipboard sebelumnya dari cadangan."

msgid "Protect mode is disabled"
msgstr "Mode proteksi dinonaktifkan"

msgid "No backup available"
msgstr "Tidak ada cadangan"

msgid "Previous clipboard restored"
msgstr "Clipboard sebelumnya dipulihkan"

msgid "Failed to restore clipboard"
msgstr "Gagal memulihkan clipboard"

msgid "Find"
msgstr "Cari"

msgid "Replace"
msgstr "Ganti"

msgid "Find what"
msgstr "Cari apa"

msgid "Source text"
msgstr "Teks asal"

msgid "Replacement text"
msgstr "Teks pengganti"

msgid "Case sensitive"
msgstr "Peka huruf besar/kecil"

msgid "Replace whole words only, not part of other words"
msgstr "Ganti hanya kata utuh, bukan bagian kata"

msgid "Find whole words only, not part of other words"
msgstr "Cari hanya kata utuh, bukan bagian kata"
msgid "Find next"
msgstr "Cari berikutnya"

msgid "Replace all"
msgstr "Ganti semua"

msgid "Find text is empty"
msgstr "Teks pencarian kosong"

msgid "Text not found"
msgstr "Teks tidak ditemukan"

msgid "{count} replacements"
msgstr "{count} penggantian"

msgid "Keep shortcuts active when buttons are hidden in editor"
msgstr "Tetap aktifkan shortcut saat tombol disembunyikan di editor"

msgid "Enable &information button in editor"
msgstr "Aktifkan tombol Informasi (&I) di editor"

msgid "Enable &find button in editor"
msgstr "Aktifkan tombol Cari (&F) di editor"

msgid "Enable &replace button in editor"
msgstr "Aktifkan tombol Ganti (&R) di editor"

msgid "Enable &protect mode (clipboard backup)"
msgstr "Aktifkan mode &proteksi (cadangan clipboard)"

msgid "Number of backup &levels"
msgstr "Jumlah &level cadangan"

msgid "Save As... (Ctrl+Shift+S)"
msgstr "Simpan Sebagai... (Ctrl+Shift+S)"

msgid "Save as"
msgstr "Simpan sebagai"

msgid "Text files (*.txt)|*.txt|All files (*.*)|*.*"
msgstr "File teks (*.txt)|*.txt|Semua file (*.*)|*.*"

msgid "File saved"
msgstr "File disimpan"

msgid "Error saving file: {error}"
msgstr "Gagal menyimpan file: {error}"

msgid "Enable &sound"
msgstr "Aktifkan &suara"

msgid "&Tools"
msgstr "Alat"

msgid "&Speech"
msgstr "Ucapan"


msgid "Convert to &uppercase"
msgstr "Ubah ke huruf &besar"

msgid "Convert to &lowercase"
msgstr "Ubah ke huruf &kecil"

msgid "Convert to &title case"
msgstr "Ubah ke format &judul"

msgid "Trim &whitespace"
msgstr "Hapus spasi tambahan"

msgid "Remove &empty lines"
msgstr "Hapus ba&ris kosong"

msgid "Strip &HTML/Formatting"
msgstr "Hapus format HTML"

msgid "Clipboard History"
msgstr "Riwayat Papan Klip"

msgid "Restore selected item"
msgstr "Pulihkan item yang dipilih"

msgid "Edit selected item"
msgstr "Edit item yang dipilih"

msgid "Delete selected item"
msgstr "Hapus item yang dipilih"

msgid "Clear all history"
msgstr "Bersihkan semua riwayat"

msgid "History size: {size}"
msgstr "Ukuran riwayat: {size}"

msgid "Are you sure you want to delete this item?"
msgstr "Apakah Anda yakin ingin menghapus item ini?"

msgid "Confirm Deletion"
msgstr "Konfirmasi Penghapusan"

msgid "Are you sure you want to clear the entire clipboard history?"
msgstr "Apakah Anda yakin ingin membersihkan seluruh riwayat papan klip?"

msgid "Confirm Clear All"
msgstr "Konfirmasi Bersihkan Semua"

msgid "Default (NVDA Language)"
msgstr "Bawaan (Bahasa NVDA)"

msgid "Addon Language (requires NVDA restart to fully apply)"
msgstr "Bahasa Addon (membutuhkan restart NVDA untuk menerapkannya)"

msgid "Clipboard History Limit"
msgstr "Batas Riwayat Papan Klip"

msgid "10 Items"
msgstr "10 Item"

msgid "25 Items"
msgstr "25 Item"

msgid "50 Items"
msgstr "50 Item"

msgid "100 Items"
msgstr "100 Item"

msgid "Unlimited"
msgstr "Tidak Terbatas"

msgid "Clipboard Content Editor Command List"
msgstr "Daftar Perintah Clipboard Content Editor"

msgid "What do you want to show?"
msgstr "Apa yang ingin Anda tampilkan?"

msgid "Command List"
msgstr "Daftar Perintah"

msgid "Full Documentation"
msgstr "Dokumentasi Lengkap"

msgid "Clipboard Content Editor Command List\n--------------------\nF1: Open Command List or Full Documentation\nA: On / Off Append Mode\nE: Open Clipboard Editor\nR: Restore Editor Backup\nI: Say Clipboard Information\nS: Speak Clipboard Content\nH: Open Clipboard History Manager"
msgstr "Daftar Perintah Clipboard Content Editor\n--------------------\nF1: Buka Daftar Perintah atau Dokumentasi Lengkap\nA: Aktifkan / Nonaktifkan Mode Tambal\nE: Buka Editor Papan Klip\nR: Pulihkan Cadangan Editor\nI: Ucapkan Informasi Papan Klip\nS: Bacakan Konten Papan Klip\nH: Buka Manajer Riwayat Papan Klip"

msgid "Clipboard Content Editor Documentation"
msgstr "Dokumentasi Clipboard Content Editor"

msgid "&Copy to Clipboard"
msgstr "Salin ke Papan Klip"

msgid "&Open in Browser"
msgstr "Buka di Browser"

msgid "&Close"
msgstr "Tutup"

msgid "Text successfully copied."
msgstr "Teks berhasil disalin."

msgid "Failed to copy text."
msgstr "Gagal menyalin teks."

msgid "Document is not available."
msgstr "Dokumen tidak tersedia."

msgid "Please restart NVDA to apply the language change."
msgstr "Silakan mulai ulang NVDA untuk menerapkan perubahan bahasa."

msgid "Restart Required"
msgstr "Dibutuhkan Mulai Ulang"

msgid " "
msgstr " "

msgid "Appended"
msgstr "Ditambahkan"

msgid "Exited Clipboard Content Editor command layer"
msgstr "Keluar dari lapisan perintah Clipboard Content Editor"

msgid "Activates Clipboard Content Editor command layer"
msgstr "Mengaktifkan lapisan perintah Clipboard Content Editor"

msgid "Enter Clipboard Content Editor command layer. Press F1 for help."
msgstr "Masuk ke lapisan perintah Clipboard Content Editor. Tekan F1 untuk bantuan"

msgid "Append mode on"
msgstr "Mode tambal diaktifkan"

msgid "Append mode off"
msgstr "Mode tambal dinonaktifkan"

msgid "Recent clipboard items:"
msgstr "Item papan klip terbaru:"

msgid "&Restore"
msgstr "Pulihkan"

msgid "&Edit"
msgstr "Edit"

msgid "&Delete"
msgstr "Hapus"

msgid "&Clear All"
msgstr "Bersihkan Semua"

msgid "&Action"
msgstr "Aksi"


msgid "Language changed. A restart of NVDA is required to fully apply the new language. Restart now?"
msgstr "Bahasa diubah. Anda harus merestart NVDA agar bahasa baru dapat diterapkan sepenuhnya. Restart sekarang?"

msgid "Clipboard Content Editor Installation"
msgstr "Instalasi Clipboard Content Editor"

msgid "Welcome to Clipboard Content Editor! Before continuing the installation, what would you like to do?"
msgstr "Selamat datang di Clipboard Content Editor! Sebelum melanjutkan instalasi, apa yang ingin Anda lakukan?"

msgid "&1. See What's New"
msgstr "&1. Lihat Apa yang Baru"

msgid "&2. Support Development (Donate)"
msgstr "&2. Dukung Pengembangan (Donasi)"

msgid "&3. Continue Installation"
msgstr "&3. Lanjutkan Instalasi"

msgid "Clipboard information: {chars} characters, {words} words, {lines} lines, {paras} paragraphs"
msgstr "Informasi papan klip: {chars} karakter, {words} kata, {lines} baris, {paras} paragraf"


